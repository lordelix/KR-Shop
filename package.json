{
  "name": "boilerplate.ts",
  "version": "5.4.8",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "generate-api-specs": "npx openapi-typescript https://api.klickrhein.de/v6/openapi.yaml -o ./src/lib/boilerplate/xioni/api/api.d.ts --make-paths-enum --root-types",
    "postinstall": "npm run generate-api-specs",
    "update": "npx npm-check-updates",
    "version:prerelease": "npm version prerelease --no-git-tag-version",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.2",
    "@eslint/js": "10.0.1",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/eslint": "9.6.1",
    "@types/node": "25",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.15.0",
    "globals": "17.5.0",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "sass": "1.100.0",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
    "sveltekit-autoimport": "1.8.2",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.1"
  },
  "type": "module",
  "dependencies": {
    "@glidejs/glide": "3.7.1",
    "@paypal/paypal-js": "9.7.0",
    "@types/glidejs__glide": "3.6.6",
    "@types/lodash-es": "4.17.12",
    "date-fns": "4.1.0",
    "lodash-es": "4.18.1",
    "openapi-fetch": "0.17.0",
    "openapi-typescript-fetch": "2.2.1",
    "opening_hours": "3.12.0",
    "svelte": "5.55.4",
    "svelte-preprocess": "6.0.3"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.27.2",
    "@rollup/rollup-linux-x64-gnu": "4.60.0"
  }
}
